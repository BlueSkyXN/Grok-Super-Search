# ======= Grok Search API 配置 =======

# 【必填】Grok SSO Token（从 grok.com Cookie 中获取 sso= 的值）
# 支持多个 token 逗号分隔，自动轮询
GROK_SSO_TOKENS=your_sso_token_here

# 【可选】API 鉴权密钥（Bearer Token），留空则不鉴权
API_KEY=

# 【可选】Cloudflare cf_clearance Cookie（反爬校验时需要）
CF_CLEARANCE=

# 【可选】User-Agent（须与获取 cf_clearance 时一致）
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36

# 【可选】服务监听配置
HOST=0.0.0.0
PORT=8000

# 【可选】默认搜索模式: auto / expert / fast
DEFAULT_MODE=auto

# 【可选】HTTP 后端: httpx（默认，轻量）/ curl_cffi（TLS 指纹模拟）
HTTP_BACKEND=httpx

# 【可选】HTTP/SOCKS5 代理
PROXY_URL=

# 【可选】请求超时（秒）
TIMEOUT=120

# 【可选】Token 冷却时间（秒），同一 Token 两次请求的最小间隔
COOLDOWN=3

# 【可选】是否使用临时对话（不保存到 Grok 历史）
TEMPORARY=true

# 【可选】搜索提示词模板（{query} 会被替换为搜索关键词）
SEARCH_PROMPT_TEMPLATE=请搜索以下内容并给出详细的搜索结果：\n\n{query}
