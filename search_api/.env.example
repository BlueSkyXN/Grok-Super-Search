# ======= Grok Search API 配置 =======
# 敏感数据放这里（.env），持久配置放 config.json

# 【必填】Grok SSO Token（从 grok.com Cookie 中获取 sso= 的值）
# 支持多个 token 逗号分隔，自动轮询 + 冷却
GROK_SSO_TOKENS=your_sso_token_here

# 【可选】API 鉴权密钥（Bearer Token），留空则不鉴权
API_KEY=

# 【可选】Cloudflare cf_clearance Cookie（反爬校验时需要）
CF_CLEARANCE=

# 【可选】User-Agent（须与获取 cf_clearance 时一致）
# USER_AGENT=Mozilla/5.0 ...

# ======= 代理配置 =======

# 【可选】单一代理（HTTP/SOCKS5）
# PROXY_URL=socks5://127.0.0.1:1080

# 【可选】代理池（逗号分隔，每次请求随机选取）
# PROXY_POOL=socks5://proxy1:1080,http://proxy2:7890,socks5://proxy3:1080

# ======= HTTP 后端 =======

# 【可选】HTTP 后端: httpx (默认) / curl_cffi (TLS 指纹) / auto (优先 curl_cffi)
# HTTP_BACKEND=httpx

# 【可选】浏览器指纹轮换（true/false，默认 true）
# 启用后每次请求使用随机浏览器指纹（UA + Sec-CH-UA + TLS impersonate）
# FINGERPRINT_ROTATION=true

# ======= WARP 代理（Cloudflare WARP）=======

# 【可选】启用 WARP 代理（true/false）
# WARP_ENABLED=false

# 【可选】WARP 模式: auto / wireproxy / kernel
# - auto: 自动检测（kernel > wireproxy）
# - wireproxy: 用户态，无需 root / NET_ADMIN
# - kernel: 内核 WireGuard + microsocks，需要 NET_ADMIN
# WARP_MODE=auto

# 【可选】WARP SOCKS5 监听端口
# WARP_SOCKS_PORT=1080

# 【可选】自定义 WARP Endpoint（默认使用 Cloudflare 官方）
# WARP_ENDPOINT=engage.cloudflareclient.com:2408

# 【可选】Base64 编码的 WireGuard 配置（Docker 部署推荐）
# WARP_CONFIG_B64=...

# ======= 服务配置 =======

# 【可选】服务监听配置（环境变量优先于 config.json）
# HOST=0.0.0.0
# PORT=8000

# 【可选】配置文件路径（默认 config.json）
# CONFIG_FILE=config.json
